# LeadFlow.AI environment template — copy to .env and fill real values
LEADFLOW_ENV=development
LEADFLOW_ALLOW_SIM_PAYMENTS=true
LEADFLOW_ALLOW_FAKE_LEADS=true

# REQUIRED for real money (your TRC-20 wallet — NOT the USDT contract address)
TRON_TREASURY_WALLET_ADDRESS=

# Telegram alerts on verified deposits
TELEGRAM_BOT_TOKEN=
ADMIN_CHAT_ID=

# Optional provider keys (phase 2)
VAPI_API_KEY=
ELEVENLABS_API_KEY=
GEMINI_API_KEY=

# Comma-separated frontend origins in production
LEADFLOW_CORS_ORIGINS=

# Disable runtime git push from cloud_deployer in production
CLOUD_AUTO_PUSH=false

PORT=8000
